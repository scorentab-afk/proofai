# Ed25519 Signing (64 hex chars — leave empty to auto-generate per request)
ED25519_PRIVATE_KEY=

# Blockchain — Polygon Amoy Testnet
ALCHEMY_API_KEY=your-alchemy-api-key
POLYGON_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
